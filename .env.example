# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# CMS seed (scripts/seed-cms.ts) — optional overrides
# -----------------------------------------------------------------------------
# CMS_ADMIN_EMAIL="admin@example.com"
# CMS_ADMIN_PASSWORD="your-secure-password"

# -----------------------------------------------------------------------------
# Public site chat widget
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CHATBOT_ENABLED="true"
# CHATBOT_API_ENABLED="true"

# -----------------------------------------------------------------------------
# LLM / site chat (/api/chat) — pick one provider
# -----------------------------------------------------------------------------
# Required together:
LLM_NAME="openai"
# openai | anthropic | gemini
LLM_API_KEY=""

# Optional: override the default model for that provider
# OpenAI default: gpt-4o-mini
# Anthropic default: claude-sonnet-4-20250514
# Gemini default: gemini-2.0-flash
# LLM_CHAT_MODEL=""

# Optional: max assistant reply tokens (256–4096, clamped in code)
# LLM_CHAT_MAX_TOKENS="768"

# -----------------------------------------------------------------------------
# LLM — advanced (only if you need them)
# -----------------------------------------------------------------------------
# Non-OpenAI OpenAI-compatible host (Groq, Together, OpenRouter, …)
# LLM_API_BASE_URL="https://api.openai.com/v1"

# OpenRouter-style extra headers (JSON object)
# LLM_EXTRA_HEADERS_JSON={"HTTP-Referer":"https://yoursite.com","X-Title":"AlignAI CMS"}

# Gemini API root (Google AI Studio); rarely needed
# LLM_GEMINI_API_ROOT="https://generativelanguage.googleapis.com/v1beta"

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# CHAT_PORT="3003"
